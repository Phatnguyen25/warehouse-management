# ============================================================
# WAREHOUSE MANAGEMENT SYSTEM - Environment Variables
# Copy this file to .env and fill in the actual values
# NEVER commit .env to version control!
# ============================================================

# ---- PostgreSQL ----
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=warehouse_db
POSTGRES_USER=warehouse_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://warehouse_user:CHANGE_ME_STRONG_PASSWORD@db:5432/warehouse_db

# ---- Neo4j AuraDB (Cloud) ----
# Get from: https://neo4j.com/cloud/aura/
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CHANGE_ME_NEO4J_PASSWORD

# ---- Google Gemini AI ----
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=CHANGE_ME_GOOGLE_API_KEY
GEMINI_MODEL=gemini-1.5-flash-latest

# ---- NextAuth.js ----
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# ---- Graphiti Service ----
GRAPHITI_SERVICE_URL=http://graphiti-service:8000
GRAPHITI_API_KEY=CHANGE_ME_INTERNAL_API_KEY

# ---- Traefik ----
TRAEFIK_ACME_EMAIL=your-email@example.com
DOMAIN=localhost

# ---- Monitoring ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
